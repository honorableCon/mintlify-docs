{
  "openapi": "3.1.0",
  "info": {
    "title": "Kiriku API",
    "description": "Kiriku API - Document Intelligence Platform. This spec focuses on Billing (credits, invoices, internal subscriptions) and admin billing endpoints.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://localhost:3009" },
    { "url": "https://api.kiriku.app" }
  ],
  "security": [
    { "bearerAuth": [] }
  ],
  "paths": {
    "/v1/billing/checkout": {
      "post": {
        "tags": ["Billing"],
        "summary": "Create a checkout session for a credit pack",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateCheckoutSessionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Checkout session created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateCheckoutSessionResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/billing/subscribe": {
      "post": {
        "tags": ["Billing"],
        "summary": "Create an internal subscription and initial invoice payment session",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateSubscriptionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateSubscriptionResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/billing/subscription/active": {
      "get": {
        "tags": ["Billing"],
        "summary": "Get active subscription for current user",
        "responses": {
          "200": {
            "description": "Active subscription",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Subscription" } } }
          }
        }
      }
    },
    "/v1/billing/subscription/cancel": {
      "post": {
        "tags": ["Billing"],
        "summary": "Cancel subscription (does not immediately downgrade; expires at endDate)",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CancelSubscriptionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription cancelled",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CancelSubscriptionResponse" } } }
          }
        }
      }
    },
    "/v1/billing/invoices": {
      "get": {
        "tags": ["Billing"],
        "summary": "List invoices for current user",
        "responses": {
          "200": {
            "description": "Invoices list",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Invoice" } }
              }
            }
          }
        }
      }
    },
    "/v1/billing/transactions": {
      "get": {
        "tags": ["Billing"],
        "summary": "List transactions for current user",
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "startDate", "in": "query", "schema": { "type": "string" } },
          { "name": "endDate", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Transactions list",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedTransactions" } } }
          }
        }
      }
    },
    "/v1/billing/admin/invoices": {
      "get": {
        "tags": ["Admin Billing"],
        "summary": "Admin: list invoices across all users",
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "startDate", "in": "query", "schema": { "type": "string" } },
          { "name": "endDate", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Invoices list",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedAdminInvoices" } } }
          }
        }
      }
    },
    "/v1/billing/admin/transactions": {
      "get": {
        "tags": ["Admin Billing"],
        "summary": "Admin: list transactions across all users",
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "offset", "in": "query", "schema": { "type": "integer" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "startDate", "in": "query", "schema": { "type": "string" } },
          { "name": "endDate", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Transactions list",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedAdminTransactions" } } }
          }
        }
      }
    },
    "/v1/billing/webhook": {
      "post": {
        "tags": ["Billing"],
        "summary": "DexPay webhook (checkout completion, failures, cancellations)",
        "parameters": [
          {
            "name": "x-webhook-signature",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "200": { "description": "Webhook processed" },
          "401": {
            "description": "Invalid signature",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "400": {
            "description": "Webhook misconfigured or invalid payload",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        },
        "security": []
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": { "message": { "type": "string" } },
        "required": ["message"]
      },
      "CreateCheckoutSessionRequest": {
        "type": "object",
        "properties": { "planId": { "type": "string" } },
        "required": ["planId"]
      },
      "CreateCheckoutSessionResponse": {
        "type": "object",
        "properties": {
          "paymentUrl": { "type": "string" },
          "reference": { "type": "string" }
        },
        "required": ["paymentUrl", "reference"]
      },
      "CreateSubscriptionRequest": {
        "type": "object",
        "properties": {
          "plan": { "type": "string" },
          "phone": { "type": "string" }
        },
        "required": ["plan"]
      },
      "CreateSubscriptionResponse": {
        "type": "object",
        "properties": {
          "subscription": { "$ref": "#/components/schemas/Subscription" },
          "paymentUrl": { "type": "string", "nullable": true }
        },
        "required": ["subscription"]
      },
      "CancelSubscriptionRequest": {
        "type": "object",
        "properties": { "subscriptionId": { "type": "string", "nullable": true } }
      },
      "CancelSubscriptionResponse": {
        "type": "object",
        "properties": { "subscription": { "$ref": "#/components/schemas/Subscription" } },
        "required": ["subscription"]
      },
      "Subscription": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "userId": { "type": "string" },
          "planId": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "pending", "cancelled", "expired", "past_due"] },
          "interval": { "type": "string", "enum": ["month", "year"] },
          "price": { "type": "number" },
          "currency": { "type": "string" },
          "startDate": { "type": "string" },
          "endDate": { "type": "string" }
        },
        "required": ["id", "planId", "status", "interval", "price", "currency", "startDate", "endDate"]
      },
      "Invoice": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "reference": { "type": "string" },
          "amount": { "type": "number" },
          "currency": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "paid", "failed", "cancelled"] },
          "dueDate": { "type": "string" },
          "paidAt": { "type": "string", "nullable": true },
          "paymentUrl": { "type": "string", "nullable": true },
          "createdAt": { "type": "string" }
        },
        "required": ["_id", "reference", "amount", "currency", "status", "dueDate", "createdAt"]
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "reference": { "type": "string" },
          "amount": { "type": "number" },
          "currency": { "type": "string" },
          "credits": { "type": "number" },
          "status": { "type": "string" },
          "type": { "type": "string" },
          "provider": { "type": "string", "nullable": true },
          "paymentMethod": { "type": "string", "nullable": true },
          "failureReason": { "type": "string", "nullable": true },
          "processedAt": { "type": "string", "nullable": true },
          "createdAt": { "type": "string" }
        },
        "required": ["id", "reference", "amount", "currency", "credits", "status", "type", "createdAt"]
      },
      "PaginatedTransactions": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Transaction" } },
          "total": { "type": "integer" }
        },
        "required": ["data", "total"]
      },
      "AdminUserSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string" },
          "firstName": { "type": "string", "nullable": true },
          "lastName": { "type": "string", "nullable": true }
        },
        "required": ["id", "email"]
      },
      "AdminInvoice": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "reference": { "type": "string" },
          "amount": { "type": "number" },
          "currency": { "type": "string" },
          "status": { "type": "string" },
          "dueDate": { "type": "string" },
          "paidAt": { "type": "string", "nullable": true },
          "paymentUrl": { "type": "string", "nullable": true },
          "createdAt": { "type": "string" },
          "user": { "$ref": "#/components/schemas/AdminUserSummary" },
          "subscription": { "type": "object", "nullable": true }
        },
        "required": ["id", "reference", "amount", "currency", "status", "dueDate", "createdAt", "user"]
      },
      "PaginatedAdminInvoices": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/AdminInvoice" } },
          "total": { "type": "integer" }
        },
        "required": ["data", "total"]
      },
      "AdminTransaction": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "reference": { "type": "string" },
          "amount": { "type": "number" },
          "currency": { "type": "string" },
          "credits": { "type": "number" },
          "status": { "type": "string" },
          "type": { "type": "string" },
          "provider": { "type": "string", "nullable": true },
          "paymentMethod": { "type": "string", "nullable": true },
          "failureReason": { "type": "string", "nullable": true },
          "processedAt": { "type": "string", "nullable": true },
          "createdAt": { "type": "string" },
          "user": { "$ref": "#/components/schemas/AdminUserSummary" }
        },
        "required": ["id", "reference", "amount", "currency", "credits", "status", "type", "createdAt", "user"]
      },
      "PaginatedAdminTransactions": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/AdminTransaction" } },
          "total": { "type": "integer" }
        },
        "required": ["data", "total"]
      }
    }
  }
}
